{
  "name": "veritas-research-radar",
  "version": "1.3.0",
  "private": true,
  "description": "Veritas browser extension plus local research job radar.",
  "scripts": {
    "start": "git pull --rebase --autostash && node radar/scripts/server.js",
    "radar:refresh": "node radar/scripts/refresh.js",
    "radar:serve": "node radar/scripts/server.js",
    "radar:import-dol": "node radar/scripts/import-dol-lca.js",
    "radar:import-scouted": "node radar/scripts/import-scouted.js",
    "radar:import-aggregated": "node radar/scripts/import-aggregated.js",
    "radar:enrich": "node radar/scripts/enrich.js",
    "scout:jobs": "scout/.venv/bin/python scout/scout_jobs.py",
    "scout:aggregators": "scout/.venv/bin/python scout/scout_aggregators.py",
    "scout:discover": "scout/.venv/bin/python scout/scout_discover.py",
    "radar:websites": "node radar/scripts/fetch-nonprofit-websites.js",
    "radar:profile": "node radar/scripts/build-profile.js",
    "radar:route": "node radar/scripts/route-resumes.js",
    "radar:digest:local": "node radar/scripts/digest-local.js",
    "test": "node tests/radar.test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "pdf-parse": "^1.1.1"
  }
}
